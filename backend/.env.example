# ==============================================================================
# VELA Backend Environment Configuration Example
# Copy this file to '.env' and fill in your values
# ==============================================================================

# Claude API Key (leave empty for demo/mock mode)
ANTHROPIC_API_KEY=

# Gemini API Key (whichever key is provided will be used; prioritized Anthropic)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Database Configuration
# Use SQLite for simple local development:
DATABASE_URL=sqlite+aiosqlite:///./vela.db
# Use Postgres for production/Docker-compose setup:
# DATABASE_URL=postgresql+asyncpg://vela:vela_dev_password@postgres:5432/vela

# Coral CLI path (for Coral integration)
CORAL_CLI_PATH=d:/On-Hackathon/Coral-demo/coral/coral.exe

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Encryption key for credentials (generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:<port>/api/connectors/google/callback

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:<port>/api/connectors/notion/callback
