# Vela Backend Configuration
# Copy to .env and fill in your values

# Claude API Key (leave empty for demo/mock mode)
ANTHROPIC_API_KEY=

# Database (SQLite default - no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./vela.db

# Coral CLI path
CORAL_CLI_PATH=d:/On-Hackathon/Coral-demo/coral/coral.exe

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Encryption key for credentials (auto-generated if empty)
FERNET_KEY=

# Google OAuth (optional - mock mode works without)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Notion OAuth (optional)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
